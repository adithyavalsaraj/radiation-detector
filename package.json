{
  "name": "wifi-locator-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:web": "npm run dev --workspace=frontend",
    "server": "npm start --workspace=backend",
    "dev:desktop": "concurrently \"npm run server\" \"npm run dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "concurrently \"npm run server\" \"npm run dev:web\"",
    "build:frontend": "npm run build --workspace=frontend",
    "build:app": "npm run build:frontend && electron-builder"
  },
  "repository": "https://github.com/adithyavalsaraj/radiation-detector",
  "build": {
    "appId": "com.wifilocator.app",
    "productName": "Radiation Tracker",
    "artifactName": "RadiationTracker-${os}.${ext}",
    "publish": [
      "github"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "1.0.0-rc.10",
    "@rolldown/binding-darwin-x64": "1.0.0-rc.10",
    "@rolldown/binding-linux-x64-gnu": "1.0.0-rc.10",
    "@rolldown/binding-win32-x64-msvc": "1.0.0-rc.10"
  },
  "main": "main.js"
}
