{
  "name": "wifi-locator-monorepo",
  "version": "1.1.2",
  "description": "WiFi Radiation Detector and Radar Tracker",
  "author": "adithyavalsaraj",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:web": "npm run dev --workspace=frontend",
    "server": "npm start --workspace=backend",
    "dev:desktop": "concurrently \"npm run server\" \"npm run dev:web\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "concurrently \"npm run server\" \"npm run dev:web\"",
    "build:frontend": "npm run build --workspace=frontend",
    "build:app": "npm run build:frontend && electron-builder",
    "build": "npm run build:frontend"
  },
  "repository": "https://github.com/adithyavalsaraj/radiation-detector",
  "build": {
    "appId": "com.wifilocator.app",
    "productName": "RadiationTracker",
    "artifactName": "${productName}-${os}-${target}.${ext}",
    "publish": [
      "github"
    ],
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "backend/**/*"
    ],
    "files": [
      "main.js",
      "backend/**/*",
      "frontend/dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "wait-on": "^7.2.0"
  },
  "optionalDependencies": {
    "lightningcss-darwin-arm64": "1.32.0",
    "lightningcss-darwin-x64": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-win32-x64-msvc": "1.32.0",
    "@esbuild/darwin-arm64": "0.27.4",
    "@esbuild/darwin-x64": "0.27.4",
    "@esbuild/linux-x64": "0.27.4",
    "@esbuild/win32-x64": "0.27.4"
  },
  "main": "main.js"
}
